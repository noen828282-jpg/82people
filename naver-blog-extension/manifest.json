{
  "manifest_version": 3,
  "name": "충주미세방충망 블로그 자동화 도우미",
  "version": "1.0.0",
  "description": "충주미세방충망 시공 후기 포스팅 작성을 지원하는 크롬 확장 프로그램입니다.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://blog.write.naver.com/*",
    "*://blog.naver.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "충주미세방충망 도우미 열기"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
