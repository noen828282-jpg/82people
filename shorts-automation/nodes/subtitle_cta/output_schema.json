{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubtitleCTAOutput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "cons": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "overall": {
          "type": "STRING"
        }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    },
    "competitor_analysis": {
      "type": "OBJECT",
      "properties": {
        "patterns": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "benchmarks": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT"
          }
        }
      },
      "required": [
        "patterns",
        "benchmarks"
      ]
    },
    "scene_briefs": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": {
            "type": "INTEGER"
          },
          "visual_description": {
            "type": "STRING"
          },
          "audio_direction": {
            "type": "STRING"
          },
          "duration_seconds": {
            "type": "NUMBER"
          }
        },
        "required": [
          "scene_number",
          "visual_description",
          "audio_direction",
          "duration_seconds"
        ]
      }
    },
    "script": {
      "type": "OBJECT",
      "properties": {
        "overall_script": {
          "type": "STRING"
        },
        "scenes_script": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": {
                "type": "INTEGER"
              },
              "narration": {
                "type": "STRING"
              }
            },
            "required": [
              "scene_number",
              "narration"
            ]
          }
        }
      },
      "required": [
        "overall_script",
        "scenes_script"
      ]
    },
    "media_prompts": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": {
            "type": "INTEGER"
          },
          "image_prompt": {
            "type": "STRING"
          },
          "video_prompt": {
            "type": "STRING"
          }
        },
        "required": [
          "scene_number",
          "image_prompt",
          "video_prompt"
        ]
      }
    },
    "media_assets": {
      "type": "OBJECT",
      "properties": {
        "videos": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": {
                "type": "INTEGER"
              },
              "file_path": {
                "type": "STRING"
              }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        },
        "images": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": {
                "type": "INTEGER"
              },
              "file_path": {
                "type": "STRING"
              }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        }
      },
      "required": [
        "videos",
        "images"
      ]
    },
    "inspection_passed": {
      "type": "BOOLEAN"
    },
    "media_inspection_details": {
      "type": "OBJECT"
    },
    "subtitle_file_path": {
      "type": "STRING",
      "description": "물리적으로 생성되어 저장된 SRT 자막 파일의 로컬 절대 경로"
    },
    "cta_overlay": {
      "type": "OBJECT",
      "properties": {
        "disclosure_banner": {
          "type": "OBJECT",
          "properties": {
            "text": { "type": "STRING" },
            "position_y_percent": { "type": "INTEGER" },
            "font_size_px": { "type": "INTEGER" },
            "background_color": { "type": "STRING" },
            "font_color": { "type": "STRING" },
            "display_mode": { "type": "STRING" }
          },
          "required": [
            "text",
            "position_y_percent",
            "font_size_px",
            "background_color",
            "font_color",
            "display_mode"
          ]
        },
        "arrow_animation": {
          "type": "OBJECT",
          "properties": {
            "scene_number": { "type": "INTEGER" },
            "position_x_percent": { "type": "INTEGER" },
            "position_y_percent": { "type": "INTEGER" },
            "animation_type": { "type": "STRING" },
            "start_seconds": { "type": "NUMBER" },
            "end_seconds": { "type": "NUMBER" },
            "target_element": { "type": "STRING" }
          },
          "required": [
            "scene_number",
            "position_x_percent",
            "position_y_percent",
            "animation_type",
            "start_seconds",
            "end_seconds",
            "target_element"
          ]
        }
      },
      "required": [
        "disclosure_banner",
        "arrow_animation"
      ],
      "description": "비디오 화면 합성 단계에서 렌더링할 자막 배너 및 애니메이션 화살표 정보 명세"
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure",
    "competitor_analysis",
    "scene_briefs",
    "script",
    "media_prompts",
    "media_assets",
    "inspection_passed",
    "media_inspection_details",
    "subtitle_file_path",
    "cta_overlay"
  ]
}
