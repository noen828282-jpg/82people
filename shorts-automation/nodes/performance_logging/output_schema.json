{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PerformanceLoggingOutput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": { "type": "ARRAY", "items": { "type": "STRING" } },
        "cons": { "type": "ARRAY", "items": { "type": "STRING" } },
        "overall": { "type": "STRING" }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    },
    "competitor_analysis": {
      "type": "OBJECT",
      "properties": {
        "patterns": { "type": "ARRAY", "items": { "type": "STRING" } },
        "benchmarks": { "type": "ARRAY", "items": { "type": "OBJECT" } }
      },
      "required": [
        "patterns",
        "benchmarks"
      ]
    },
    "scene_briefs": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": { "type": "INTEGER" },
          "visual_description": { "type": "STRING" },
          "audio_direction": { "type": "STRING" },
          "duration_seconds": { "type": "NUMBER" }
        },
        "required": [
          "scene_number",
          "visual_description",
          "audio_direction",
          "duration_seconds"
        ]
      }
    },
    "script": {
      "type": "OBJECT",
      "properties": {
        "overall_script": { "type": "STRING" },
        "scenes_script": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": { "type": "INTEGER" },
              "narration": { "type": "STRING" }
            },
            "required": [
              "scene_number",
              "narration"
            ]
          }
        }
      },
      "required": [
        "overall_script",
        "scenes_script"
      ]
    },
    "media_prompts": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": { "type": "INTEGER" },
          "image_prompt": { "type": "STRING" },
          "video_prompt": { "type": "STRING" }
        },
        "required": [
          "scene_number",
          "image_prompt",
          "video_prompt"
        ]
      }
    },
    "media_assets": {
      "type": "OBJECT",
      "properties": {
        "videos": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": { "type": "INTEGER" },
              "file_path": { "type": "STRING" }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        },
        "images": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": { "type": "INTEGER" },
              "file_path": { "type": "STRING" }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        }
      },
      "required": [
        "videos",
        "images"
      ]
    },
    "inspection_passed": {
      "type": "BOOLEAN"
    },
    "media_inspection_details": {
      "type": "OBJECT"
    },
    "subtitle_file_path": {
      "type": "STRING"
    },
    "cta_overlay": {
      "type": "OBJECT"
    },
    "package_dir": {
      "type": "STRING"
    },
    "manifest_file": {
      "type": "STRING"
    },
    "upload_package": {
      "type": "OBJECT"
    },
    "approval_status": {
      "type": "OBJECT"
    },
    "performance_log": {
      "type": "OBJECT",
      "properties": {
        "logged_at": { "type": "STRING", "format": "date-time" },
        "metrics": {
          "type": "OBJECT",
          "properties": {
            "views": { "type": "INTEGER" },
            "likes": { "type": "INTEGER" },
            "comments": { "type": "INTEGER" },
            "shares": { "type": "INTEGER" },
            "clicks": { "type": "INTEGER" },
            "conversions": { "type": "INTEGER" },
            "revenue_krw": { "type": "INTEGER" }
          },
          "required": [
            "views",
            "likes",
            "comments",
            "shares",
            "clicks",
            "conversions",
            "revenue_krw"
          ]
        }
      },
      "required": [
        "logged_at",
        "metrics"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure",
    "competitor_analysis",
    "scene_briefs",
    "script",
    "media_prompts",
    "media_assets",
    "inspection_passed",
    "media_inspection_details",
    "subtitle_file_path",
    "cta_overlay",
    "package_dir",
    "manifest_file",
    "upload_package",
    "approval_status",
    "performance_log"
  ]
}
