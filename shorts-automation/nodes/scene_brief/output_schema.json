{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SceneBriefOutput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "cons": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "overall": {
          "type": "STRING"
        }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    },
    "competitor_analysis": {
      "type": "OBJECT",
      "properties": {
        "patterns": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "benchmarks": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT"
          }
        }
      },
      "required": [
        "patterns",
        "benchmarks"
      ]
    },
    "scene_briefs": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": {
            "type": "INTEGER"
          },
          "visual_description": {
            "type": "STRING",
            "description": "해당 장면에 표시되어야 할 화면 연출 및 구성 요약"
          },
          "audio_direction": {
            "type": "STRING",
            "description": "해당 장면에서 연출될 효과음 또는 내레이션 기획 요약"
          },
          "duration_seconds": {
            "type": "NUMBER",
            "description": "장면 길이 (초)"
          }
        },
        "required": [
          "scene_number",
          "visual_description",
          "audio_direction",
          "duration_seconds"
        ]
      },
      "description": "쇼츠 대본 생성을 위해 설계된 씬별 연출 브리프 리스트"
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure",
    "competitor_analysis",
    "scene_briefs"
  ]
}
