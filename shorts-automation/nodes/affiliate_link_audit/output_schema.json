{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AffiliateLinkAuditOutput",
  "type": "ARRAY",
  "items": {
    "type": "OBJECT",
    "properties": {
      "id": {
        "type": [
          "STRING",
          "INTEGER"
        ]
      },
      "name": {
        "type": "STRING"
      },
      "url": {
        "type": "STRING",
        "format": "uri"
      },
      "category": {
        "type": "STRING"
      },
      "price": {
        "type": "INTEGER"
      },
      "description": {
        "type": "STRING"
      },
      "images": {
        "type": "ARRAY",
        "items": {
          "type": "STRING",
          "format": "uri"
        }
      },
      "reviews": {
        "type": "ARRAY",
        "items": {
          "type": "STRING"
        }
      },
      "score": {
        "type": "NUMBER"
      },
      "review_summary": {
        "type": "OBJECT",
        "properties": {
          "pros": {
            "type": "ARRAY",
            "items": {
              "type": "STRING"
            }
          },
          "cons": {
            "type": "ARRAY",
            "items": {
              "type": "STRING"
            }
          },
          "overall": {
            "type": "STRING"
          }
        },
        "required": [
          "pros",
          "cons",
          "overall"
        ]
      },
      "risk": {
        "type": "BOOLEAN"
      },
      "reason": {
        "type": "STRING"
      },
      "affiliate_url": {
        "type": "STRING",
        "format": "uri",
        "description": "생성 또는 검증 완료된 수익 제휴용 링크"
      },
      "disclosure": {
        "type": "STRING",
        "description": "공정거래위원회 가이드라인을 준수하는 제휴 대가성 명시 문구"
      }
    },
    "required": [
      "id",
      "name",
      "url",
      "category",
      "price",
      "description",
      "images",
      "reviews",
      "score",
      "review_summary",
      "risk",
      "reason",
      "affiliate_url",
      "disclosure"
    ]
  }
}
