{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompetitorPatternInput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "cons": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "overall": {
          "type": "STRING"
        }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure"
  ]
}
