{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompetitorPatternOutput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "cons": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "overall": {
          "type": "STRING"
        }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    },
    "competitor_analysis": {
      "type": "OBJECT",
      "properties": {
        "patterns": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          },
          "description": "추천 비디오 제작 포맷/스타일 태그 목록"
        },
        "benchmarks": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "title": {
                "type": "STRING"
              },
              "views": {
                "type": "INTEGER"
              },
              "hook_style": {
                "type": "STRING"
              },
              "visual_style": {
                "type": "STRING"
              }
            },
            "required": [
              "title",
              "views",
              "hook_style",
              "visual_style"
            ]
          },
          "description": "유튜브/인스타그램에서 분석된 벤치마킹 쇼츠 정보 목록"
        }
      },
      "required": [
        "patterns",
        "benchmarks"
      ]
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure",
    "competitor_analysis"
  ]
}
