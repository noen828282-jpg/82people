{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductCandidateCollectionOutput",
  "type": "ARRAY",
  "items": {
    "type": "OBJECT",
    "properties": {
      "id": {
        "type": [
          "STRING",
          "INTEGER"
        ],
        "description": "상품 고유 식별자"
      },
      "name": {
        "type": "STRING",
        "description": "상품명"
      },
      "url": {
        "type": "STRING",
        "format": "uri",
        "description": "상품 원본 URL 또는 구매 페이지 링크"
      },
      "category": {
        "type": "STRING",
        "description": "상품 카테고리 분류"
      },
      "price": {
        "type": "INTEGER",
        "description": "상품 가격"
      },
      "description": {
        "type": "STRING",
        "description": "상품 상세 설명"
      },
      "images": {
        "type": "ARRAY",
        "items": {
          "type": "STRING",
          "format": "uri"
        },
        "description": "상품 이미지 URL 목록"
      }
    },
    "required": [
      "id",
      "name",
      "url"
    ]
  }
}
