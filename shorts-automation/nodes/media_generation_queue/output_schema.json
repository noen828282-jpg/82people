{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MediaGenerationQueueOutput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "cons": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "overall": {
          "type": "STRING"
        }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    },
    "competitor_analysis": {
      "type": "OBJECT",
      "properties": {
        "patterns": {
          "type": "ARRAY",
          "items": {
            "type": "STRING"
          }
        },
        "benchmarks": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT"
          }
        }
      },
      "required": [
        "patterns",
        "benchmarks"
      ]
    },
    "scene_briefs": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": {
            "type": "INTEGER"
          },
          "visual_description": {
            "type": "STRING"
          },
          "audio_direction": {
            "type": "STRING"
          },
          "duration_seconds": {
            "type": "NUMBER"
          }
        },
        "required": [
          "scene_number",
          "visual_description",
          "audio_direction",
          "duration_seconds"
        ]
      }
    },
    "script": {
      "type": "OBJECT",
      "properties": {
        "overall_script": {
          "type": "STRING"
        },
        "scenes_script": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": {
                "type": "INTEGER"
              },
              "narration": {
                "type": "STRING"
              }
            },
            "required": [
              "scene_number",
              "narration"
            ]
          }
        }
      },
      "required": [
        "overall_script",
        "scenes_script"
      ]
    },
    "media_prompts": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": {
            "type": "INTEGER"
          },
          "image_prompt": {
            "type": "STRING"
          },
          "video_prompt": {
            "type": "STRING"
          }
        },
        "required": [
          "scene_number",
          "image_prompt",
          "video_prompt"
        ]
      }
    },
    "media_assets": {
      "type": "OBJECT",
      "properties": {
        "videos": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": {
                "type": "INTEGER"
              },
              "file_path": {
                "type": "STRING",
                "description": "생성 완료 후 로컬에 다운로드 저장된 비디오 파일 절대 경로"
              }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        },
        "images": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": {
                "type": "INTEGER"
              },
              "file_path": {
                "type": "STRING",
                "description": "생성 완료 후 로컬에 다운로드 저장된 이미지 파일 절대 경로"
              }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        }
      },
      "required": [
        "videos",
        "images"
      ],
      "description": "로컬 저장소에 보관된 장면별 미디어 원본 파일 리스트"
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure",
    "competitor_analysis",
    "scene_briefs",
    "script",
    "media_prompts",
    "media_assets"
  ]
}
