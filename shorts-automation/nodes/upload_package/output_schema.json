{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UploadPackageOutput",
  "type": "OBJECT",
  "properties": {
    "id": {
      "type": [
        "STRING",
        "INTEGER"
      ]
    },
    "name": {
      "type": "STRING"
    },
    "url": {
      "type": "STRING",
      "format": "uri"
    },
    "category": {
      "type": "STRING"
    },
    "price": {
      "type": "INTEGER"
    },
    "description": {
      "type": "STRING"
    },
    "images": {
      "type": "ARRAY",
      "items": {
        "type": "STRING",
        "format": "uri"
      }
    },
    "reviews": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      }
    },
    "score": {
      "type": "NUMBER"
    },
    "review_summary": {
      "type": "OBJECT",
      "properties": {
        "pros": { "type": "ARRAY", "items": { "type": "STRING" } },
        "cons": { "type": "ARRAY", "items": { "type": "STRING" } },
        "overall": { "type": "STRING" }
      },
      "required": [
        "pros",
        "cons",
        "overall"
      ]
    },
    "risk": {
      "type": "BOOLEAN"
    },
    "reason": {
      "type": "STRING"
    },
    "affiliate_url": {
      "type": "STRING",
      "format": "uri"
    },
    "disclosure": {
      "type": "STRING"
    },
    "competitor_analysis": {
      "type": "OBJECT",
      "properties": {
        "patterns": { "type": "ARRAY", "items": { "type": "STRING" } },
        "benchmarks": { "type": "ARRAY", "items": { "type": "OBJECT" } }
      },
      "required": [
        "patterns",
        "benchmarks"
      ]
    },
    "scene_briefs": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": { "type": "INTEGER" },
          "visual_description": { "type": "STRING" },
          "audio_direction": { "type": "STRING" },
          "duration_seconds": { "type": "NUMBER" }
        },
        "required": [
          "scene_number",
          "visual_description",
          "audio_direction",
          "duration_seconds"
        ]
      }
    },
    "script": {
      "type": "OBJECT",
      "properties": {
        "overall_script": { "type": "STRING" },
        "scenes_script": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": { "type": "INTEGER" },
              "narration": { "type": "STRING" }
            },
            "required": [
              "scene_number",
              "narration"
            ]
          }
        }
      },
      "required": [
        "overall_script",
        "scenes_script"
      ]
    },
    "media_prompts": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT",
        "properties": {
          "scene_number": { "type": "INTEGER" },
          "image_prompt": { "type": "STRING" },
          "video_prompt": { "type": "STRING" }
        },
        "required": [
          "scene_number",
          "image_prompt",
          "video_prompt"
        ]
      }
    },
    "media_assets": {
      "type": "OBJECT",
      "properties": {
        "videos": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": { "type": "INTEGER" },
              "file_path": { "type": "STRING" }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        },
        "images": {
          "type": "ARRAY",
          "items": {
            "type": "OBJECT",
            "properties": {
              "scene_number": { "type": "INTEGER" },
              "file_path": { "type": "STRING" }
            },
            "required": [
              "scene_number",
              "file_path"
            ]
          }
        }
      },
      "required": [
        "videos",
        "images"
      ]
    },
    "inspection_passed": {
      "type": "BOOLEAN"
    },
    "media_inspection_details": {
      "type": "OBJECT"
    },
    "subtitle_file_path": {
      "type": "STRING"
    },
    "cta_overlay": {
      "type": "OBJECT"
    },
    "package_dir": {
      "type": "STRING",
      "description": "업로드 패키지가 모인 독립 디렉토리 절대 경로"
    },
    "manifest_file": {
      "type": "STRING",
      "description": "패키지 자산 상태를 명시한 JSON 파일 절대 경로"
    },
    "upload_package": {
      "type": "OBJECT",
      "properties": {
        "prod_id": { "type": "STRING" },
        "title": { "type": "STRING" },
        "description": { "type": "STRING" },
        "tags": {
          "type": "ARRAY",
          "items": { "type": "STRING" }
        },
        "video_files": {
          "type": "ARRAY",
          "items": { "type": "STRING" }
        },
        "subtitle_file": { "type": "STRING" }
      },
      "required": [
        "prod_id",
        "title",
        "description",
        "tags",
        "video_files",
        "subtitle_file"
      ],
      "description": "최종 업로더가 파싱해서 자동 업로드할 때 직접 사용할 파라미터 셋"
    }
  },
  "required": [
    "id",
    "name",
    "url",
    "category",
    "price",
    "description",
    "images",
    "reviews",
    "score",
    "review_summary",
    "risk",
    "reason",
    "affiliate_url",
    "disclosure",
    "competitor_analysis",
    "scene_briefs",
    "script",
    "media_prompts",
    "media_assets",
    "inspection_passed",
    "media_inspection_details",
    "subtitle_file_path",
    "cta_overlay",
    "package_dir",
    "manifest_file",
    "upload_package"
  ]
}
