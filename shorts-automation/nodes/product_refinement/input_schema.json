{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductRefinementInput",
  "type": "ARRAY",
  "items": {
    "type": "OBJECT",
    "properties": {
      "id": {
        "type": [
          "STRING",
          "INTEGER"
        ]
      },
      "name": {
        "type": "STRING"
      },
      "url": {
        "type": "STRING",
        "format": "uri"
      },
      "category": {
        "type": "STRING"
      },
      "price": {
        "type": "INTEGER"
      },
      "description": {
        "type": "STRING"
      },
      "images": {
        "type": "ARRAY",
        "items": {
          "type": "STRING"
        }
      }
    },
    "required": [
      "id",
      "name",
      "url"
    ]
  }
}
