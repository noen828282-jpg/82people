{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductScoringOutput",
  "type": "ARRAY",
  "items": {
    "type": "OBJECT",
    "properties": {
      "id": {
        "type": [
          "STRING",
          "INTEGER"
        ]
      },
      "name": {
        "type": "STRING"
      },
      "url": {
        "type": "STRING",
        "format": "uri"
      },
      "category": {
        "type": "STRING"
      },
      "price": {
        "type": "INTEGER"
      },
      "description": {
        "type": "STRING"
      },
      "images": {
        "type": "ARRAY",
        "items": {
          "type": "STRING",
          "format": "uri"
        }
      },
      "reviews": {
        "type": "ARRAY",
        "items": {
          "type": "STRING"
        }
      },
      "score": {
        "type": "NUMBER",
        "minimum": 0.0,
        "maximum": 5.0,
        "description": "최종 산출된 상품 우선순위 점수 (0.0 ~ 5.0)"
      },
      "review_summary": {
        "type": "OBJECT",
        "properties": {
          "pros": {
            "type": "ARRAY",
            "items": {
              "type": "STRING"
            },
            "description": "긍정적인 요점 목록"
          },
          "cons": {
            "type": "ARRAY",
            "items": {
              "type": "STRING"
            },
            "description": "아쉬운 점 또는 단점 목록"
          },
          "overall": {
            "type": "STRING",
            "description": "종합 리뷰 요약 한 줄"
          }
        },
        "required": [
          "pros",
          "cons",
          "overall"
        ]
      }
    },
    "required": [
      "id",
      "name",
      "url",
      "category",
      "price",
      "description",
      "images",
      "reviews",
      "score",
      "review_summary"
    ]
  }
}
