{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RegulationCheckOutput",
  "type": "ARRAY",
  "items": {
    "type": "OBJECT",
    "properties": {
      "id": {
        "type": [
          "STRING",
          "INTEGER"
        ]
      },
      "name": {
        "type": "STRING"
      },
      "url": {
        "type": "STRING",
        "format": "uri"
      },
      "category": {
        "type": "STRING"
      },
      "price": {
        "type": "INTEGER"
      },
      "description": {
        "type": "STRING"
      },
      "images": {
        "type": "ARRAY",
        "items": {
          "type": "STRING",
          "format": "uri"
        }
      },
      "reviews": {
        "type": "ARRAY",
        "items": {
          "type": "STRING"
        }
      },
      "score": {
        "type": "NUMBER"
      },
      "review_summary": {
        "type": "OBJECT",
        "properties": {
          "pros": {
            "type": "ARRAY",
            "items": {
              "type": "STRING"
            }
          },
          "cons": {
            "type": "ARRAY",
            "items": {
              "type": "STRING"
            }
          },
          "overall": {
            "type": "STRING"
          }
        },
        "required": [
          "pros",
          "cons",
          "overall"
        ]
      },
      "risk": {
        "type": "BOOLEAN",
        "description": "광고 심의 규정 위반 리스크 감지 여부"
      },
      "reason": {
        "type": "STRING",
        "description": "리스크 감지 시 세부 항목 및 사유 설명"
      }
    },
    "required": [
      "id",
      "name",
      "url",
      "category",
      "price",
      "description",
      "images",
      "reviews",
      "score",
      "review_summary",
      "risk",
      "reason"
    ]
  }
}
